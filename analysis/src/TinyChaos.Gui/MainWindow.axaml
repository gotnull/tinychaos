<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:TinyChaos.Gui"
        xmlns:local="using:TinyChaos.Gui"
        mc:Ignorable="d"
        x:Class="TinyChaos.Gui.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="tinychaos"
        Width="1180" Height="780"
        MinWidth="960" MinHeight="640"
        Background="{DynamicResource Surface2}"
        FontFamily="-apple-system,system-ui,Segoe UI,Helvetica Neue,Arial,sans-serif"
        FontSize="13">

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">

        <!-- ========================================= -->
        <!-- Persistent connection toolbar              -->
        <!-- ========================================= -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,12">
            <Grid RowDefinitions="Auto,12,Auto,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Classes="h1" Text="CONNECTION" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding StatusDotBrush}"
                                 VerticalAlignment="Center" />
                        <TextBlock Classes="caption"
                                   Text="{Binding ConnectionStatusText}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2"
                      ColumnDefinitions="Auto,*,20,Auto,220,Auto,Auto,Auto"
                      RowDefinitions="Auto">
                    <TextBlock Grid.Column="0" Classes="formLabel" Text="Port" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailablePorts}"
                              SelectedItem="{Binding SelectedPort, Mode=TwoWay}"
                              PlaceholderText="select a serial port"
                              HorizontalAlignment="Stretch" />

                    <TextBlock Grid.Column="3" Classes="formLabel" Text="Label" />
                    <TextBox    Grid.Column="4"
                                Text="{Binding ValidationLabel, Mode=TwoWay}"
                                Watermark="zener, divider, floating, ..." />

                    <Button Grid.Column="5" Classes="secondary"
                            Command="{Binding RefreshPortsCommand}"
                            Content="Refresh"
                            Margin="20,0,0,0" />
                    <Button Grid.Column="6" Classes="secondary"
                            Command="{Binding ToggleRecordingCommand}"
                            Content="{Binding RecordButtonLabel}"
                            Margin="10,0,0,0" />
                    <Button Grid.Column="7" Classes="primary"
                            Command="{Binding ToggleConnectionCommand}"
                            Content="{Binding ConnectButtonLabel}"
                            Margin="10,0,0,0" />
                </Grid>

                <!-- Recording-path readout, shown only while recording -->
                <TextBlock Grid.Row="3"
                           Classes="caption"
                           Margin="0,8,0,0"
                           Text="{Binding RecordingPathText, StringFormat='recording to {0}'}"
                           IsVisible="{Binding IsRecording}"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- ========================================= -->
        <!-- Tab control with three contextual panels   -->
        <!-- ========================================= -->
        <TabControl Grid.Row="1" Padding="0">

            <!-- ============== LIVE CAPTURE ============== -->
            <TabItem Header="Live capture">
                <Grid RowDefinitions="*,12,*,12,Auto" Margin="0,12,0,0">

                    <!-- Waveform card -->
                    <Border Grid.Row="0" Classes="card">
                        <Grid RowDefinitions="Auto,12,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="h1" Text="WAVEFORM" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Classes="swatch" Background="{DynamicResource Channel0Brush}" />
                                        <TextBlock Classes="caption" Text="channel 0 (zener)" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border Classes="swatch" Background="{DynamicResource Channel1Brush}" />
                                        <TextBlock Classes="caption" Text="channel 1 (baseline)" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <Border Grid.Row="2" Classes="chartHolder">
                                <local:WaveformView Model="{Binding Waveform}" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Histogram card -->
                    <Border Grid.Row="2" Classes="card">
                        <Grid RowDefinitions="Auto,12,*">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0" Classes="h1" Text="DISTRIBUTION" />
                                <TextBlock Grid.Column="1" Classes="caption" Text="ADC code: 0 to 4095 (12-bit)" />
                            </Grid>
                            <Border Grid.Row="2" Classes="chartHolder">
                                <local:HistogramView Model="{Binding Histogram}" />
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Statistics card -->
                    <Border Grid.Row="4" Classes="card">
                        <Grid RowDefinitions="Auto,8,Auto">
                            <TextBlock Grid.Row="0" Classes="h1" Text="PER-CHANNEL STATISTICS" />
                            <TextBlock Grid.Row="2" Classes="mono" Text="{Binding StatsText}" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ============== SAMPLES ============== -->
            <TabItem Header="Samples">
                <Border Classes="card" Margin="0,12,0,0">
                    <Grid RowDefinitions="Auto,10,*" ColumnDefinitions="*">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Classes="h1" Text="SAMPLES" />
                                <TextBlock Classes="caption" Text="{Binding SamplesStatusText}" />
                                <TextBlock Classes="caption" Text="{Binding SamplesDirectory}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Classes="secondary"
                                        Command="{Binding RefreshSamplesCommand}"
                                        Content="Refresh" />
                                <Button Classes="secondary"
                                        Command="{Binding OpenSamplesFolderCommand}"
                                        Content="Open folder" />
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding Samples}"
                                 SelectedItem="{Binding SelectedSample, Mode=TwoWay}"
                                 Background="{DynamicResource Surface0}"
                                 BorderBrush="{DynamicResource SurfaceBorderSoft}"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 Padding="2">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="vm:SampleEntry">
                                    <Grid ColumnDefinitions="*,Auto,160" Margin="6,6">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FileName}"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SizeText}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontFamily="Menlo,Consolas,monospace"
                                                   FontSize="11"
                                                   Margin="12,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ModifiedText}"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ============== FIRMWARE ============== -->
            <TabItem Header="Firmware">
                <Border Classes="card" Margin="0,12,0,0">
                    <Grid RowDefinitions="Auto,12,*" ColumnDefinitions="*">

                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Classes="h1" Text="BUILD &amp; FLASH" />
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Ellipse Width="8" Height="8" Fill="{Binding BuildStatusDotBrush}" VerticalAlignment="Center" />
                                    <TextBlock Classes="caption" Text="{Binding BuildStatusText}" />
                                </StackPanel>
                                <TextBlock Classes="caption" Text="{Binding FirmwareDirectory}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Classes="secondary"
                                        Command="{Binding RunFirmwareSelfTestCommand}"
                                        IsEnabled="{Binding !IsBusyBuilding}"
                                        Content="Self-test" />
                                <Button Classes="secondary"
                                        Command="{Binding ClearBuildLogCommand}"
                                        Content="Clear" />
                                <Button Classes="secondary"
                                        Command="{Binding BuildFirmwareCommand}"
                                        IsEnabled="{Binding !IsBusyBuilding}"
                                        Content="Build" />
                                <Button Classes="primary"
                                        Command="{Binding FlashFirmwareCommand}"
                                        IsEnabled="{Binding !IsBusyBuilding}"
                                        Content="Flash" />
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      Background="{DynamicResource Surface0}"
                                      BorderBrush="{DynamicResource SurfaceBorderSoft}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      Padding="12,10">
                            <TextBlock Text="{Binding BuildLog}"
                                       FontFamily="Menlo,Consolas,Courier New,monospace"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </TabItem>

        </TabControl>

        <!-- ========================================= -->
        <!-- Status footer (persistent across tabs)     -->
        <!-- ========================================= -->
        <Border Grid.Row="2" Classes="card" Margin="0,12,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="mode" />
                        <TextBlock Classes="mono" Text="{Binding ModeText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="pkts" />
                        <TextBlock Classes="mono" Text="{Binding PacketsText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="bad_crc" />
                        <TextBlock Classes="mono" Text="{Binding BadCrcText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="drops" />
                        <TextBlock Classes="mono" Text="{Binding DropsText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="resync" />
                        <TextBlock Classes="mono" Text="{Binding ResyncText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="stm32" />
                        <TextBlock Classes="mono" Text="{Binding Stm32RateText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="host" />
                        <TextBlock Classes="mono" Text="{Binding HostRateText}" />
                    </StackPanel>
                </Border>
                <Border Classes="statusPill" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="mono secondary" Text="label" />
                        <TextBlock Classes="mono" Text="{Binding ValidationLabelEcho}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
