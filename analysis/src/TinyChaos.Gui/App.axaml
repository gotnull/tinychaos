<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TinyChaos.Gui.App"
             RequestedThemeVariant="Dark">

    <!-- Custom macOS application menu. Supplying our own NativeMenu replaces
         Avalonia's built-in default (which shows a generic "About Avalonia"
         dialog) with a tinychaos About plus the standard Hide/Quit items. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About Tiny Chaos" Click="OnAbout" />
            <NativeMenuItemSeparator />
            <NativeMenuItem Header="Quit Tiny Chaos" Gesture="Cmd+Q" Click="OnQuit" />
        </NativeMenu>
    </NativeMenu.Menu>

    <Application.Styles>
        <FluentTheme />

        <!-- Section header. Small uppercase eyebrow label, not a headline.
             Inspired by Linear / Stripe / Notion section markers: low chroma,
             medium weight, generous letter-spacing for legibility at small
             size. -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="LetterSpacing" Value="1.2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Subtle subheader / caption -->
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>

        <!-- Tabular monospaced text -->
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Menlo,Consolas,Courier New,monospace" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>

        <Style Selector="TextBlock.mono.secondary">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>

        <!-- Form label (sits immediately to the left of an input) -->
        <Style Selector="TextBlock.formLabel">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>

        <!-- Card surface -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource Surface1}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <!-- Inner chart background -->
        <Style Selector="Border.chartHolder">
            <Setter Property="Background" Value="{DynamicResource Surface0}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <!-- Base button (applies to every button in the app) -->
        <Style Selector="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Primary action button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.primary /template/ ContentPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentHover}" />
        </Style>

        <!-- Secondary button -->
        <Style Selector="Button.secondary">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style Selector="Button.secondary /template/ ContentPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- Record button: a strong red accent so the recording control is
             visually distinct from the primary action. Label toggles between
             "Record" and "Stop"; colour stays red because the button always
             refers to the recording state. -->
        <Style Selector="Button.record">
            <Setter Property="Background" Value="{DynamicResource Record}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource Record}" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.record /template/ ContentPresenter">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.record:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource RecordHover}" />
            <Setter Property="BorderBrush" Value="{DynamicResource RecordHover}" />
        </Style>

        <!-- Channel legend swatch -->
        <Style Selector="Border.swatch">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Status pill: label + value badge -->
        <Style Selector="Border.statusPill">
            <Setter Property="Background" Value="{DynamicResource Surface0}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ComboBox typography fine-tune -->
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="ComboBox /template/ ContentPresenter#ContentPresenter">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- TextBox typography fine-tune -->
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <!-- TabControl + TabItem polish.
             Fluent defaults render tab headers in a bold 14px+ which fights
             with the small uppercase section labels inside each tab. Bring
             them down to 12px Medium, no border underneath, and let the
             selected tab indicator carry the active-state weight. -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Padding" Value="2,6" />
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <!-- TextBox watermark/placeholder vertical centering -->
        <Style Selector="TextBox /template/ TextBlock#PART_Watermark">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox /template/ TextPresenter#PART_TextPresenter">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <!-- ====== Design token palette ====== -->
            <!-- Surfaces (deepest to lightest) -->
            <Color x:Key="Surface0Color">#0E1218</Color>
            <Color x:Key="Surface1Color">#161B24</Color>
            <Color x:Key="Surface2Color">#1E2531</Color>

            <!-- Borders -->
            <Color x:Key="SurfaceBorderColor">#2A3140</Color>
            <Color x:Key="SurfaceBorderSoftColor">#1F2632</Color>

            <!-- Text -->
            <Color x:Key="TextPrimaryColor">#E8ECF2</Color>
            <Color x:Key="TextSecondaryColor">#8E96A6</Color>
            <Color x:Key="TextTertiaryColor">#5A6373</Color>

            <!-- Accent (primary action) -->
            <Color x:Key="AccentColor">#3B82F6</Color>
            <Color x:Key="AccentHoverColor">#5B9DF8</Color>

            <!-- Record (destructive / live-capture write) -->
            <Color x:Key="RecordColor">#E5484D</Color>
            <Color x:Key="RecordHoverColor">#EF5961</Color>

            <!-- Channel palette (for legend swatches; views own their own copies) -->
            <Color x:Key="Channel0Color">#4FC3F7</Color>
            <Color x:Key="Channel1Color">#FF8040</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="Surface0" Color="{StaticResource Surface0Color}" />
            <SolidColorBrush x:Key="Surface1" Color="{StaticResource Surface1Color}" />
            <SolidColorBrush x:Key="Surface2" Color="{StaticResource Surface2Color}" />
            <SolidColorBrush x:Key="SurfaceBorder" Color="{StaticResource SurfaceBorderColor}" />
            <SolidColorBrush x:Key="SurfaceBorderSoft" Color="{StaticResource SurfaceBorderSoftColor}" />
            <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="TextTertiary" Color="{StaticResource TextTertiaryColor}" />
            <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}" />
            <SolidColorBrush x:Key="Record" Color="{StaticResource RecordColor}" />
            <SolidColorBrush x:Key="RecordHover" Color="{StaticResource RecordHoverColor}" />
            <SolidColorBrush x:Key="Channel0Brush" Color="{StaticResource Channel0Color}" />
            <SolidColorBrush x:Key="Channel1Brush" Color="{StaticResource Channel1Color}" />

            <!-- Spacing scale -->
            <x:Double x:Key="Space1">4</x:Double>
            <x:Double x:Key="Space2">8</x:Double>
            <x:Double x:Key="Space3">12</x:Double>
            <x:Double x:Key="Space4">16</x:Double>
            <x:Double x:Key="Space5">24</x:Double>
            <x:Double x:Key="Space6">32</x:Double>
        </ResourceDictionary>
    </Application.Resources>

</Application>
