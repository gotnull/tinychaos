<?xml version="1.0" encoding="UTF-8"?>
<!--
  Info.plist for the tinychaos.app macOS bundle (assembled by package-mac.sh).

  This is what gives the app its macOS identity that Window.Icon cannot:
    - CFBundleName / CFBundleDisplayName -> the bold app-menu title reads
      "tinychaos" instead of "Avalonia Application".
    - CFBundleIconFile -> the Dock / Finder / cmd-tab icon (tinychaos.icns in
      Contents/Resources).
    - CFBundleShortVersionString / NSHumanReadableCopyright -> shown in the
      standard About box.
  CFBundleExecutable must match the .NET apphost name (AssemblyName in the
  .csproj = "tinychaos-gui").
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>tinychaos</string>
    <key>CFBundleDisplayName</key>
    <string>tinychaos</string>
    <key>CFBundleIdentifier</key>
    <string>io.github.gotnull.tinychaos</string>
    <key>CFBundleExecutable</key>
    <string>tinychaos-gui</string>
    <key>CFBundleIconFile</key>
    <string>tinychaos</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>
    <key>NSHumanReadableCopyright</key>
    <string>tinychaos - avalanche-noise hardware RNG</string>
</dict>
</plist>
