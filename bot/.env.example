# --- tinychaos Telegram bot config -------------------------------------------
# Token for a NEW bot created via @BotFather (do NOT reuse StrozzBot's).
TELEGRAM_BOT_TOKEN=

# One-time: run `claude setup-token` on this machine and paste the result here.
# This lets `claude -p` authenticate headless (no browser) when the bot runs as
# a service. load_dotenv puts it in the environment, which the claude subprocess
# inherits - so you do NOT also need it in the launchd plist.
CLAUDE_CODE_OAUTH_TOKEN=

# --- optional ----------------------------------------------------------------
# TINYCHAOS_BOT_MODEL=claude-sonnet-4-6        # or claude-opus-4-8 for hard Qs
# TINYCHAOS_BOT_ALLOWED_CHATS=-1001234567890   # comma-sep chat IDs; empty = any
# TINYCHAOS_BOT_COOLDOWN=15                     # per-user seconds between /ask
# TINYCHAOS_BOT_OWNER=680585616               # admin user id for /reset
