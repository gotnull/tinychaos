# Sample captures: track only the demo files; user-recorded captures
# (e.g. capture-YYYYMMDD-HHMMSS.bin, zener-YYYYMMDD-HHMMSS.bin, anything
# written by the GUI Record button or the CLI --raw-bin) stay ignored.
#
# Without these explicit negations the *.bin catch-all in the firmware
# section above would silently ignore the seeded demo files too.
!samples/
!samples/README.md
!samples/floating_50hz.bin
!samples/sine_1khz.bin
!samples/zener_synthetic.bin

# Claude Code harness runtime locks
.claude/scheduled_tasks.lock
